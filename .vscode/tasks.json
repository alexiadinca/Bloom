{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build backend",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/backend/Bloom.Api/Bloom.Api.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "npm install frontend",
      "type": "shell",
      "command": "npm",
      "args": [
        "install"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend/bloom-client"
      },
      "problemMatcher": []
    },
    {
      "label": "serve frontend",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "start"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend/bloom-client"
      },
      "dependsOn": [
        "npm install frontend"
      ],
      "dependsOrder": "sequence",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*Local:.*"
        }
      }
    }
  ]
}
